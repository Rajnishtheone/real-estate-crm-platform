generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  AGENT
  BUYER
  NRI
}

enum PropertyStatus {
  DRAFT
  PENDING
  ACTIVE
  REJECTED
  SOLD
}

enum PropertyType {
  APARTMENT
  VILLA
  PLOT
  COMMERCIAL
}

enum LeadStatus {
  NEW
  CONTACTED
  NEGOTIATION
  CLOSED
}

enum DocumentType {
  OWNERSHIP
  LEASE
  LEGAL
  ID_PROOF
  RECEIPT
}

enum PaymentStatus {
  DUE
  PAID
  OVERDUE
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  phone          String?
  passwordHash   String
  role           Role
  status         String   @default("active")
  tokenVersion   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  properties     Property[] @relation("PropertyOwner")
  assignedProperties Property[] @relation("PropertyAgent")
  leads          Lead[]    @relation("LeadBuyer")
  assignedLeads  Lead[]    @relation("LeadAgent")
  documents      Document[]
  nriAccounts    NriAccount[]
  managedNri     NriAccount[] @relation("NriManager")
  refreshTokens  RefreshToken[]
}

model Property {
  id           String   @id @default(cuid())
  title        String
  description  String
  locationCity String
  locationCountry String
  price        Decimal  @db.Decimal(12,2)
  type         PropertyType
  bedrooms     Int
  bathrooms    Int
  amenities    Json?
  status       PropertyStatus @default(DRAFT)
  owner        User     @relation("PropertyOwner", fields: [ownerId], references: [id])
  ownerId      String
  agent        User     @relation("PropertyAgent", fields: [agentId], references: [id])
  agentId      String
  images       PropertyImage[]
  leads        Lead[]
  documents    Document[] @relation("PropertyDocuments")
  rentPayments RentPayment[]
  nriAccount   NriAccount? @relation(fields: [nriAccountId], references: [id])
  nriAccountId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([locationCity])
  @@index([price])
  @@index([type])
  @@index([status])
}

model PropertyImage {
  id          String   @id @default(cuid())
  url         String
  altText     String?
  ordering    Int       @default(0)
  property    Property  @relation(fields: [propertyId], references: [id])
  propertyId  String
}

model Lead {
  id               String   @id @default(cuid())
  name             String
  email            String
  phone            String?
  message          String?
  status           LeadStatus @default(NEW)
  property         Property @relation(fields: [propertyId], references: [id])
  propertyId       String
  buyer            User?    @relation("LeadBuyer", fields: [buyerId], references: [id])
  buyerId          String?
  assignedAgent    User     @relation("LeadAgent", fields: [assignedAgentId], references: [id])
  assignedAgentId  String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Document {
  id            String   @id @default(cuid())
  owner         User     @relation(fields: [ownerUserId], references: [id])
  ownerUserId   String
  property      Property? @relation("PropertyDocuments", fields: [propertyId], references: [id])
  propertyId    String?
  nriAccount    NriAccount? @relation(fields: [nriAccountId], references: [id])
  nriAccountId  String?
  type          DocumentType
  url           String
  fileName      String
  mimeType      String
  sizeBytes     Int
  createdAt     DateTime @default(now())
  receipts      RentPayment[] @relation("ReceiptDocument")
}

model NriAccount {
  id           String    @id @default(cuid())
  user         User      @relation(fields: [userId], references: [id])
  userId       String
  manager      User?     @relation("NriManager", fields: [managerUserId], references: [id])
  managerUserId String?
  timezone     String?
  notes        String?
  properties   Property[]
  documents    Document[]
  rentPayments RentPayment[]
}

model RentPayment {
  id            String   @id @default(cuid())
  nriAccount    NriAccount @relation(fields: [nriAccountId], references: [id])
  nriAccountId  String
  property      Property   @relation(fields: [propertyId], references: [id])
  propertyId    String
  amount        Decimal @db.Decimal(12,2)
  dueDate       DateTime
  paidDate      DateTime?
  status        PaymentStatus @default(DUE)
  receipt       Document? @relation("ReceiptDocument", fields: [receiptDocId], references: [id])
  receiptDocId  String?
}

model RefreshToken {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  jti        String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
}
